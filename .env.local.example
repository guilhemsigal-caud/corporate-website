# ─────────────────────────────────────────────────────────────────
# Collective Audience — Next.js environment variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.
# ─────────────────────────────────────────────────────────────────

# ── Sanity CMS ────────────────────────────────────────────────────
# Project ID and dataset are public (already hardcoded in src/sanity/client.ts)
NEXT_PUBLIC_SANITY_PROJECT_ID=2svafw8h
NEXT_PUBLIC_SANITY_DATASET=production

# API token with "Viewer" role minimum — used for draft-mode preview (server-side only)
# Generate one at: https://www.sanity.io/manage/project/2svafw8h/api#tokens
SANITY_API_TOKEN=

# URL of the Sanity Studio (used by Visual Editing / Presentation tool)
# Local dev:   http://localhost:3333
# Production:  https://your-studio.sanity.studio  (or your custom domain)
SANITY_STUDIO_URL=http://localhost:3333

# ── Draft-mode / Preview ──────────────────────────────────────────
# Secret used to validate /api/draft-mode/enable requests.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SANITY_REVALIDATE_SECRET=

# ── Site URL ──────────────────────────────────────────────────────
# Used by the Studio Presentation tool to open the live preview.
# Local dev:   http://localhost:3000
# Production:  https://www.collectiveaudience.co
NEXT_PUBLIC_SITE_URL=http://localhost:3000
